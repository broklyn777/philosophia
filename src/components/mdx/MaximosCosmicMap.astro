<figure class="cosmic-map" data-cosmic-map data-state="fracture" aria-labelledby="cosmic-map-title">
  <header class="cosmic-map__header">
    <p class="cosmic-map__eyebrow">En karta över rörelsen mot Gud</p>
    <h2 id="cosmic-map-title">Från splittring till förening i Logos</h2>
    <p>
      Maximos ser människans inre liv, Kristi verk och skapelsens mål som delar
      av samma mysterium.
    </p>
  </header>

  <div class="cosmic-map__steps" role="group" aria-label="Tre rörelser hos Maximos">
    <button type="button" data-cosmic-state="fracture" aria-pressed="true">
      <span>I</span> Splittring
    </button>
    <button type="button" data-cosmic-state="discernment" aria-pressed="false">
      <span>II</span> Urskiljning
    </button>
    <button type="button" data-cosmic-state="union" aria-pressed="false">
      <span>III</span> Förening
    </button>
  </div>

  <div class="cosmic-map__body">
    <div class="cosmic-map__scene" aria-hidden="true">
      <div class="cosmic-map__logos">
        <span></span>
        <p>Logos</p>
      </div>

      <div class="cosmic-map__orbit cosmic-map__orbit--outer"></div>
      <div class="cosmic-map__orbit cosmic-map__orbit--inner"></div>

      <div class="cosmic-map__human">
        <span class="cosmic-map__head"></span>
        <span class="cosmic-map__body-mark"></span>
        <span class="cosmic-map__heart"></span>
      </div>

      <div class="cosmic-map__logos-fragments">
        <span class="fragment fragment--earth">jord<small>gåva</small></span>
        <span class="fragment fragment--neighbor">nästan<small>gemenskap</small></span>
        <span class="fragment fragment--body">kropp<small>förkroppsligande</small></span>
        <span class="fragment fragment--mind">ande<small>kontemplation</small></span>
      </div>

      <div class="cosmic-map__divisions">
        <span>jag / världen</span>
        <span>ande / materia</span>
        <span>människa / nästan</span>
      </div>

      <div class="cosmic-map__lines">
        <span></span><span></span><span></span><span></span>
      </div>
    </div>

    <div class="cosmic-map__texts" aria-live="polite">
      <section data-cosmic-panel="fracture">
        <p class="cosmic-map__number">I</p>
        <h3>Splittring</h3>
        <p class="cosmic-map__lead">Det skapade rycks loss från sin mening.</p>
        <p>
          När kärleken böjs in mot jaget blir världen material för begär,
          kontroll och rädsla. Människan söndrar det hon är kallad att förena.
        </p>
        <blockquote>Synden gör relation till avstånd.</blockquote>
      </section>

      <section data-cosmic-panel="discernment" hidden>
        <p class="cosmic-map__number">II</p>
        <h3>Urskiljning av logoi</h3>
        <p class="cosmic-map__lead">Skapelsen börjar åter framträda som gåva.</p>
        <p>
          Genom rening och kontemplation lär sig människan att se varje varelse
          enligt dess gudgivna mening, inte bara enligt hennes eget bruk.
        </p>
        <blockquote>Att se en logos är att ana skapelsen i relation till Kristus.</blockquote>
      </section>

      <section data-cosmic-panel="union" hidden>
        <p class="cosmic-map__number">III</p>
        <h3>Förening i Logos</h3>
        <p class="cosmic-map__lead">Det åtskilda samlas utan att skillnaderna utplånas.</p>
        <p>
          I Kristus helas människans vilja och kärlek. Hon blir en medlare som
          tar emot världen, förenar det splittrade och bär skapelsen mot Gud.
        </p>
        <blockquote>Förening är inte sammanblandning, utan fullbordad gemenskap.</blockquote>
      </section>
    </div>
  </div>

  <figcaption>
    Den andliga vägen är kosmisk: när människan lär sig älska rätt börjar också
    hennes relation till hela skapelsen att helas.
  </figcaption>
</figure>

<script>
  document.querySelectorAll<HTMLElement>("[data-cosmic-map]").forEach((map) => {
    const buttons = map.querySelectorAll<HTMLButtonElement>("[data-cosmic-state]");
    const panels = map.querySelectorAll<HTMLElement>("[data-cosmic-panel]");

    const setState = (state: "fracture" | "discernment" | "union") => {
      map.dataset.state = state;
      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.cosmicState === state));
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.cosmicPanel !== state;
      });
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const state = button.dataset.cosmicState;
        if (state === "fracture" || state === "discernment" || state === "union") {
          setState(state);
        }
      });
    });
  });
</script>

