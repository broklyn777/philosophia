<figure class="human-map" data-human-map data-state="created" aria-labelledby="human-map-title">
  <header class="human-map__header">
    <p class="human-map__eyebrow">Människan enligt Evagrios</p>
    <h2 id="human-map-title">Från enhet, genom splittring, mot läkedom</h2>
    <p>
      Den andliga vägen börjar inte i självförakt. Den börjar i minnet av vad
      människan är skapad för.
    </p>
  </header>

  <div class="human-map__steps" role="group" aria-label="Människans väg enligt Evagrios">
    <button type="button" data-human-state="created" aria-pressed="true">
      <span>I</span> Skapad för Gud
    </button>
    <button type="button" data-human-state="divided" aria-pressed="false">
      <span>II</span> Splittrad av logismoi
    </button>
    <button type="button" data-human-state="healed" aria-pressed="false">
      <span>III</span> Helad på vägen
    </button>
  </div>

  <div class="human-map__body">
    <div class="human-map__scene" aria-hidden="true">
      <div class="human-map__light">
        <span></span>
        <p>Gud</p>
      </div>
      <div class="human-map__ray"></div>

      <div class="human-map__person">
        <span class="human-map__head"></span>
        <span class="human-map__torso"></span>
        <span class="human-map__heart"></span>
        <span class="human-map__gaze"></span>
      </div>

      <div class="human-map__force human-map__force--reason">
        <span class="human-map__force-mark"></span>
        <p>förnuft<small data-created-label>klarhet</small></p>
      </div>
      <div class="human-map__force human-map__force--spirit">
        <span class="human-map__force-mark"></span>
        <p>kraft<small data-created-label>mod</small></p>
      </div>
      <div class="human-map__force human-map__force--desire">
        <span class="human-map__force-mark"></span>
        <p>begär<small data-created-label>längtan</small></p>
      </div>

      <div class="human-map__world">
        <span class="human-map__horizon"></span>
        <span class="human-map__other"></span>
        <span class="human-map__creation"></span>
        <p data-human-world>skapelsen som gåva</p>
      </div>

      <div class="human-map__distortions">
        <span class="distortion distortion--desire">begär<small>den andre blir ett objekt</small></span>
        <span class="distortion distortion--anger">vrede<small>den andre blir en fiende</small></span>
        <span class="distortion distortion--vanity">fåfänga<small>livet blir en scen</small></span>
        <span class="distortion distortion--acedia">akedia<small>det goda tycks tomt</small></span>
      </div>

      <div class="human-map__path">
        <span>vaksamhet</span>
        <span>askes</span>
        <span>apatheia</span>
        <span>bön</span>
        <span>kärlek</span>
        <span>renat nous</span>
      </div>
    </div>

    <div class="human-map__texts" aria-live="polite">
      <section data-human-panel="created">
        <p class="human-map__number">I</p>
        <h3>Skapad för Gud</h3>
        <p class="human-map__lead">Människans krafter är från början gåvor.</p>
        <p>
          Människan är skapad för klarhet, kärlek och gemenskap med Gud.
          Förnuft, kraft och begär är inte fiender, utan krafter som i sitt
          friska tillstånd samverkar.
        </p>
        <blockquote>
          Människan är i sitt djup inte skapad för kaos, utan för enhet.
        </blockquote>
      </section>

      <section data-human-panel="divided" hidden>
        <p class="human-map__number">II</p>
        <h3>Splittrad av logismoi</h3>
        <p class="human-map__lead">Passionen drar isär både kärleken och blicken.</p>
        <p>
          Människans problem är inte bara att hon gör fel. Logismoi förvränger
          seendet, binder begäret och gör nästan till objekt, hot eller spegel
          för jaget.
        </p>
        <blockquote>
          Det stora problemet är inte bara moralisk skuld, utan förvrängt seende
          och splittrad kärlek.
        </blockquote>
      </section>

      <section data-human-panel="healed" hidden>
        <p class="human-map__number">III</p>
        <h3>Helad genom den andliga vägen</h3>
        <p class="human-map__lead">Inte perfektion, utan ett långsamt återvändande.</p>
        <p>
          Genom vaksamhet, askes, bön och apatheia blir själen friare, seendet
          klarare och människan mer samlad. Krafterna utplånas inte; de riktas
          åter mot kärleken.
        </p>
        <blockquote>
          Frälsningen är inte bara att få veta något nytt, utan att bli helad.
        </blockquote>
      </section>
    </div>
  </div>

  <figcaption>
    Evagrios karta börjar i skapelsen och slutar inte i tekniken, utan i en
    människa som långsamt samlas inför Gud.
  </figcaption>
</figure>

<script>
  const humanWorldLabels = {
    created: "skapelsen som gåva",
    divided: "världen genom passionens blick",
    healed: "skapelsen mottagen på nytt",
  };

  const forceLabels = {
    created: ["klarhet", "mod", "längtan"],
    divided: ["självbedrägeri", "vrede och flykt", "rastlös hunger"],
    healed: ["urskiljning", "uthållighet", "längtan efter Gud"],
  };

  document.querySelectorAll<HTMLElement>("[data-human-map]").forEach((map) => {
    const buttons = map.querySelectorAll<HTMLButtonElement>("[data-human-state]");
    const panels = map.querySelectorAll<HTMLElement>("[data-human-panel]");
    const labels = map.querySelectorAll<HTMLElement>("[data-created-label]");
    const world = map.querySelector<HTMLElement>("[data-human-world]");

    const setState = (state: "created" | "divided" | "healed") => {
      map.dataset.state = state;
      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.humanState === state));
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.humanPanel !== state;
      });
      labels.forEach((label, index) => {
        label.textContent = forceLabels[state][index] ?? "";
      });
      if (world) world.textContent = humanWorldLabels[state];
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const state = button.dataset.humanState;
        if (state === "created" || state === "divided" || state === "healed") {
          setState(state);
        }
      });
    });
  });
</script>

