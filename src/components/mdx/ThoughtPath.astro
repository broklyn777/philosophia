---
const steps = [
  ["Förslag", "En tanke, bild eller impuls träder in."],
  ["Samtal", "Människan börjar resonera med tanken."],
  ["Dröjande", "Hon stannar kvar vid bilden eller berättelsen."],
  ["Samtycke", "Hon gör tankens riktning till sin egen."],
  ["Handling", "Tanken blir uttryckt i ord eller gärning."],
  ["Vana", "Handlingar upprepas och formar själen."],
  ["Passion", "Vanan blir ett herravälde."],
];
---

<figure class="thought-path" aria-labelledby="thought-path-caption">
  <p class="thought-path__eyebrow">Tankens väg genom själen</p>
  <ol>
    {steps.map(([title, description], index) => (
      <li>
        <span class="thought-path__index">{String(index + 1).padStart(2, "0")}</span>
        <div>
          <h3>{title}</h3>
          <p>{description}</p>
        </div>
      </li>
    ))}
  </ol>
  <figcaption id="thought-path-caption">
    Den första tanken är inte alltid människans fel. Men när tanken får samtal,
    dröjande och samtycke börjar den forma hjärtat.
  </figcaption>
</figure>

<style>
  .thought-path {
    margin: 46px 0 52px;
    padding: 28px clamp(20px, 5vw, 42px) 32px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 45%),
      var(--surface);
  }

  .thought-path__eyebrow {
    margin-bottom: 26px;
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 16px;
    min-height: 86px;
    padding-bottom: 20px;
  }

  li:not(:last-child)::before {
    position: absolute;
    top: 38px;
    bottom: 0;
    left: 18px;
    width: 1px;
    background: linear-gradient(var(--accent), color-mix(in srgb, var(--accent) 28%, transparent));
    content: "";
  }

  .thought-path__index {
    display: grid;
    place-items: center;
    align-self: start;
    width: 37px;
    height: 37px;
    border: 1px solid color-mix(in srgb, var(--accent) 48%, var(--line));
    border-radius: 50%;
    background: var(--bg);
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 700;
  }

  h3 {
    margin: 1px 0 4px !important;
    font-size: 1.2rem !important;
  }

  li p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
  }

  figcaption {
    margin-top: 8px;
    padding: 18px 0 0 58px;
    border-top: 1px solid var(--line);
    color: var(--ink);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.04rem;
    font-style: italic;
    line-height: 1.65;
  }

  @media (max-width: 520px) {
    figcaption {
      padding-left: 0;
    }
  }
</style>
