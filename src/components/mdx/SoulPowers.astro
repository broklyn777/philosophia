<figure class="soul-visual" data-soul-visual data-state="unified" aria-labelledby="soul-visual-title">
  <header class="soul-visual__header">
    <div>
      <p class="soul-visual__eyebrow">Själens tre krafter</p>
      <h3 id="soul-visual-title" data-heading>När själen är samlad</h3>
      <p class="soul-visual__description" data-description>
        Förnuft, kraft och begär riktas mot samma mål.
      </p>
    </div>

    <div class="soul-visual__toggle" role="group" aria-label="Visa själens tillstånd">
      <button type="button" data-state-button="unified" aria-pressed="true">Samlad</button>
      <button type="button" data-state-button="divided" aria-pressed="false">Splittrad</button>
    </div>
  </header>

  <div class="soul-visual__stage" aria-live="polite">
    <div class="soul-visual__axis" aria-hidden="true">
      <span></span>
    </div>

    <article class="soul-force soul-force--reason">
      <span class="soul-force__arrow" aria-hidden="true"></span>
      <div class="soul-force__body">
        <p class="soul-force__name">Förnuftet</p>
        <p class="soul-force__greek">logistikon · λογιστικόν</p>
        <p class="soul-force__meaning">
          <span data-unified>urskiljning och bön</span>
          <span data-divided hidden>högmod och självbedrägeri</span>
        </p>
      </div>
    </article>

    <article class="soul-force soul-force--spirit">
      <span class="soul-force__arrow" aria-hidden="true"></span>
      <div class="soul-force__body">
        <p class="soul-force__name">Vredeskraften</p>
        <p class="soul-force__greek">thymikon · θυμικόν</p>
        <p class="soul-force__meaning">
          <span data-unified>mod och uthållighet</span>
          <span data-divided hidden>vrede, bitterhet och flykt</span>
        </p>
      </div>
    </article>

    <article class="soul-force soul-force--desire">
      <span class="soul-force__arrow" aria-hidden="true"></span>
      <div class="soul-force__body">
        <p class="soul-force__name">Begäret</p>
        <p class="soul-force__greek">epithymetikon · ἐπιθυμητικόν</p>
        <p class="soul-force__meaning">
          <span data-unified>längtan efter Gud</span>
          <span data-divided hidden>rastlös hunger, frosseri och girighet</span>
        </p>
      </div>
    </article>
  </div>

  <figcaption>
    Samma krafter finns kvar i båda lägena. Frågan är om de samlas i en riktning
    eller dras isär av logismoi.
  </figcaption>
</figure>

<script>
  const headings = {
    unified: "När själen är samlad",
    divided: "När logismoi splittrar själen",
  };

  const descriptions = {
    unified: "Förnuft, kraft och begär riktas mot samma mål.",
    divided: "Tankarna drar människans inre krafter åt olika håll.",
  };

  document.querySelectorAll<HTMLElement>("[data-soul-visual]").forEach((visual) => {
    const heading = visual.querySelector<HTMLElement>("[data-heading]");
    const description = visual.querySelector<HTMLElement>("[data-description]");
    const buttons = visual.querySelectorAll<HTMLButtonElement>("[data-state-button]");

    const setState = (state: "unified" | "divided") => {
      visual.dataset.state = state;
      if (heading) heading.textContent = headings[state];
      if (description) description.textContent = descriptions[state];

      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.stateButton === state));
      });

      visual.querySelectorAll<HTMLElement>("[data-unified]").forEach((element) => {
        element.hidden = state !== "unified";
      });
      visual.querySelectorAll<HTMLElement>("[data-divided]").forEach((element) => {
        element.hidden = state !== "divided";
      });
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setState(button.dataset.stateButton === "divided" ? "divided" : "unified");
      });
    });
  });
</script>

