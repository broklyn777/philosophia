<figure class="nous-map" data-nous-map data-state="natural" aria-labelledby="nous-map-title">
  <header class="nous-map__header">
    <p class="nous-map__eyebrow">En karta över det inre seendet</p>
    <h3 id="nous-map-title">Nous ser inte bara <em>något</em> — det ser på ett sätt</h3>
    <p>
      Verkligheten är densamma. Men själens blick kan ta emot den, förvränga den
      eller åter lära sig att se.
    </p>
  </header>

  <div class="nous-map__steps" role="group" aria-label="Nous tre tillstånd">
    <button type="button" data-nous-state="natural" aria-pressed="true">
      <span>1</span> Naturligt kall
    </button>
    <button type="button" data-nous-state="darkened" aria-pressed="false">
      <span>2</span> Förmörkat
    </button>
    <button type="button" data-nous-state="cleansed" aria-pressed="false">
      <span>3</span> Renas
    </button>
  </div>

  <div class="nous-map__body">
    <div class="nous-map__vision" aria-hidden="true">
      <div class="nous-map__source">
        <span></span>
        <p>Gud</p>
      </div>

      <div class="nous-map__beam"></div>

      <div class="nous-map__eye">
        <div class="nous-map__iris">
          <span class="nous-map__pupil"></span>
        </div>
      </div>

      <div class="nous-map__world">
        <span class="nous-map__horizon"></span>
        <span class="nous-map__person"></span>
        <span class="nous-map__tree"></span>
        <p data-world-label>skapelsen som gåva</p>
      </div>

      <div class="nous-map__fog">
        <span class="fog fog--desire">begär<small>den andre reduceras till ett objekt</small></span>
        <span class="fog fog--anger">vrede<small>den andre blir en fiende</small></span>
        <span class="fog fog--vanity">fåfänga<small>livet blir en scen</small></span>
        <span class="fog fog--acedia">akedia<small>det goda tycks tomt</small></span>
      </div>

      <div class="nous-map__cleansing">
        <span>vaksamhet</span>
        <span>askes</span>
        <span>bön</span>
        <span>apatheia</span>
      </div>
    </div>

    <div class="nous-map__texts" aria-live="polite">
      <section data-nous-panel="natural">
        <p class="nous-map__number">I</p>
        <h4>Nous i sitt naturliga kall</h4>
        <p class="nous-map__lead">Klart, stilla och mottagligt.</p>
        <p>
          Själens öga är inte vänt mot sig självt. Det tar emot ljus, riktas mot
          Gud och låter det skapade framträda som gåva.
        </p>
        <blockquote>Att se sant är här en form av relation.</blockquote>
      </section>

      <section data-nous-panel="darkened" hidden>
        <p class="nous-map__number">II</p>
        <h4>Nous förmörkas av logismoi</h4>
        <p class="nous-map__lead">Blicken ser fortfarande — men den ser skevt.</p>
        <p>
          Vrede, begär, fåfänga och akedia lägger sina egna betydelser över
          verkligheten. Människan gör inte bara fel. Hon börjar uppfatta nästan,
          världen och sig själv genom passionens lins.
        </p>
        <blockquote>Logismos övertygar blicken om att förvrängningen är verkligheten.</blockquote>
      </section>

      <section data-nous-panel="cleansed" hidden>
        <p class="nous-map__number">III</p>
        <h4>Nous renas</h4>
        <p class="nous-map__lead">Dimman skingras; seendet återfår sin enkelhet.</p>
        <p>
          Vaksamhet avslöjar tanken. Askes löser dess grepp. Bön återvänder till
          Gud. Apatheia gör blicken friare från passionens tvång.
        </p>
        <blockquote>Reningen skapar inte ett nytt öga. Den helar det öga människan redan fått.</blockquote>
      </section>
    </div>
  </div>

  <figcaption>
    Logismoi förändrar inte först världen utanför människan. De förändrar den
    blick genom vilken världen möts.
  </figcaption>
</figure>

<script>
  const worldLabels = {
    natural: "skapelsen som gåva",
    darkened: "verkligheten genom passionen",
    cleansed: "skapelsen sedd på nytt",
  };

  document.querySelectorAll<HTMLElement>("[data-nous-map]").forEach((map) => {
    const buttons = map.querySelectorAll<HTMLButtonElement>("[data-nous-state]");
    const panels = map.querySelectorAll<HTMLElement>("[data-nous-panel]");
    const worldLabel = map.querySelector<HTMLElement>("[data-world-label]");

    const setState = (state: "natural" | "darkened" | "cleansed") => {
      map.dataset.state = state;
      buttons.forEach((button) => {
        button.setAttribute("aria-pressed", String(button.dataset.nousState === state));
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.nousPanel !== state;
      });
      if (worldLabel) worldLabel.textContent = worldLabels[state];
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const state = button.dataset.nousState;
        if (state === "natural" || state === "darkened" || state === "cleansed") {
          setState(state);
        }
      });
    });
  });
</script>

