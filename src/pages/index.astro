---
import ArticleCard from "../components/ArticleCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getProjects, getPublishedPosts } from "../lib/content";

const posts = (await getPublishedPosts()).slice(0, 4);
const projects = (await getProjects()).filter((project) => project.data.featured).slice(0, 3);
---

<BaseLayout
  title="Philosophia"
  description="En webbplats för filosofi, teologi, andlig psykologi och sammanhållna studier."
>
  <main>
    <section class="hero">
      <p class="eyebrow">Filosofi och teologi</p>
      <h1>Anteckningar om människan, Gud och det inre livet.</h1>
      <p class="lead">
        Philosophia samlar essäer, läsanteckningar och studier om filosofi,
        teologi, asketisk psykologi och praktisk självrannsakan.
      </p>
      <div class="actions">
        <a href="/blog/">Läs bloggen</a>
        <a href="/projekt/">Öppna biblioteket</a>
        <a href="/boner/">Lyssna på böner</a>
      </div>
    </section>

    <section class="section featured-series" aria-labelledby="det-osynliga-kriget">
      <div>
        <p class="eyebrow">Ny serie · Ortodox antropologi</p>
        <h2 id="det-osynliga-kriget">Det osynliga kriget</h2>
        <p>
          Vad är kroppen, själen och anden — och hur återställs människans
          inre ordning? Följ en sammanhängande väg från antropologins grunder
          till den andliga vardagens praktik.
        </p>
      </div>
      <ol aria-label="Publicerade delar">
        <li><a href="/vad-ar-kroppen/"><span>01</span> Vad är kroppen?</a></li>
        <li><a href="/vad-ar-sjalen/"><span>02</span> Vad är själen?</a></li>
        <li><a href="/vad-ar-anden/"><span>03</span> Vad är anden?</a></li>
        <li><a href="/hur-paverkar-kropp-sjal-och-ande-varandra/"><span>04</span> Hur påverkar de varandra?</a></li>
        <li><a href="/vad-ar-en-passion/"><span>05</span> Vad är en passion?</a></li>
        <li><a href="/hur-aterstalls-den-inre-ordningen/"><span>06</span> Hur återställs den inre ordningen?</a></li>
        <li><a href="/hur-praktiseras-detta-i-vardagen/"><span>07</span> Hur praktiseras detta i vardagen?</a></li>
      </ol>
      <a class="featured-series__action" href="/det-osynliga-kriget/">
        Öppna serien <span aria-hidden="true">→</span>
      </a>
    </section>

    <section class="section audio-entry" aria-labelledby="inlasta-boner">
      <div>
        <p class="eyebrow">Stillhet</p>
        <h2 id="inlasta-boner">Inlästa böner och sånger</h2>
      </div>
      <p>
        Lyssna på ortodoxa böner och sånger i bysantinsk stil, med texter och
        möjlighet att ladda ned MP3.
      </p>
      <a href="/boner/">Öppna ljudbiblioteket</a>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Bibliotek</p>
        <h2>Pågående studier</h2>
      </div>
      <div class="project-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Senaste</p>
        <h2>Blogg</h2>
      </div>
      <div>
        {posts.map((post) => <ArticleCard post={post} />)}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    min-height: 62vh;
    display: grid;
    align-content: center;
    padding: 54px 0;
    border-bottom: 1px solid var(--line);
  }

  h1 {
    max-width: 920px;
    margin-bottom: 20px;
    font-size: clamp(3rem, 8vw, 6.7rem);
    line-height: 0.92;
    letter-spacing: -0.055em;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
  }

  .actions a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    padding: 0 18px;
    border: 1px solid var(--accent);
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-weight: 800;
    text-decoration: none;
  }

  .actions a + a {
    background: transparent;
    color: var(--accent);
    font-weight: 400;
  }

  .section {
    padding: 46px 0;
    border-bottom: 1px solid var(--line);
  }

  .section-heading h2 {
    margin-bottom: 22px;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .featured-series {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.75fr);
    gap: 30px 48px;
    padding: clamp(30px, 6vw, 56px);
    border: 1px solid var(--line);
    border-radius: 12px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 56%),
      var(--surface);
  }

  .featured-series h2 {
    margin-bottom: 16px;
    font-size: clamp(2.5rem, 6vw, 4.8rem);
    line-height: 0.94;
    letter-spacing: -0.045em;
  }

  .featured-series div > p:last-child {
    max-width: 660px;
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .featured-series ol {
    align-self: center;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .featured-series li {
    border-bottom: 1px solid var(--line);
  }

  .featured-series li a {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 10px;
    padding: 13px 0;
    text-decoration: none;
  }

  .featured-series li span {
    color: var(--accent);
    font-size: 0.76rem;
  }

  .featured-series__action {
    grid-column: 1 / -1;
    width: fit-content;
    color: var(--accent);
    text-decoration: none;
  }

  .audio-entry {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.2fr) auto;
    gap: 24px;
    align-items: center;
  }

  .audio-entry h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .audio-entry p:not(.eyebrow) {
    max-width: 620px;
    color: var(--muted);
    line-height: 1.65;
  }

  .audio-entry a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border: 1px solid var(--accent);
    border-radius: 8px;
    color: var(--accent);
    font-weight: 400;
    text-decoration: none;
    white-space: nowrap;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 760px) {
    .hero {
      min-height: auto;
      padding-top: 34px;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .featured-series {
      grid-template-columns: 1fr;
    }

    .audio-entry {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .audio-entry a {
      width: fit-content;
    }
  }
</style>
