---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection(
    "projects",
    ({ data }) => !data.path && (!import.meta.env.PROD || data.status !== "draft"),
  );
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <main>
    <header class="page-heading">
      <p class="eyebrow">Bibliotek</p>
      <h1>{project.data.title}</h1>
      <p class="lead">{project.data.description}</p>
    </header>
    <article class="prose project-body">
      <Content />
    </article>
  </main>
</BaseLayout>

<style>
  .project-body {
    padding-top: 32px;
  }
</style>
