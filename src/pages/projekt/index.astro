---
import ProjectCard from "../../components/ProjectCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/content";

const projects = await getProjects();
---

<BaseLayout title="Bibliotek" description="Sammanhållna studier och innehållsserier.">
  <main>
    <header class="page-heading">
      <p class="eyebrow">Bibliotek</p>
      <h1>Pågående studier</h1>
      <p class="lead">
        Sammanhållna studier med innehållssidor, läsordningar och relaterade artiklar.
      </p>
    </header>
    <section class="project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
  </main>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    padding-top: 32px;
  }

  @media (max-width: 760px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
