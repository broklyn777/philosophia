---
import BaseLayout from "../layouts/BaseLayout.astro";

const resultTemplate = `
  <li class="pf-result philosophia-result">
    <div class="philosophia-result__body">
      <p class="philosophia-result__title">
        <a href="{{ meta.url | default(url) | safeUrl }}">{{ meta.resultTitle }}</a>
      </p>
      {{#if excerpt}}
      <p class="philosophia-result__excerpt">{{+ excerpt +}}</p>
      {{/if}}
    </div>
    {{#if sub_results}}
    <ul class="philosophia-result__sections">
      {{#each sub_results as sub}}
      <li>
        <a href="{{ sub.url | safeUrl }}">{{ sub.title }}</a>
      </li>
      {{/each}}
    </ul>
    {{/if}}
  </li>
`;
---

<BaseLayout
  title="Sök"
  description="Sök bland Philosophias essäer om filosofi, teologi och andlig psykologi."
>
  <link slot="head" href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
  <script is:inline slot="head" src="/pagefind/pagefind-component-ui.js" type="module"></script>

  <main data-pagefind-ignore="all">
    <header class="search-heading">
      <p class="eyebrow">Bibliotek</p>
      <h1>Sök</h1>
      <p class="lead">Sök i essäer, studier och anteckningar.</p>
    </header>

    <section class="search-library" aria-label="Sök i Philosophia">
      <pagefind-config excerpt-length="28"></pagefind-config>
      <div class="search-field">
        <pagefind-input
          placeholder="Sök efter ett namn, begrepp eller ämne"
          autofocus
        ></pagefind-input>
        <span class="search-shortcut" aria-hidden="true">⌘ K</span>
      </div>
      <pagefind-summary default-message="Börja skriva för att söka i biblioteket.">
      </pagefind-summary>
      <pagefind-results max-results="10" max-sub-results="2">
        <script
          is:inline
          type="text/pagefind-template"
          set:html={resultTemplate}
        ></script>
      </pagefind-results>
    </section>
  </main>
</BaseLayout>

<script>
  const shortcut = document.querySelector<HTMLElement>(".search-shortcut");
  if (shortcut && !navigator.userAgent.toLowerCase().includes("mac")) {
    shortcut.textContent = "Ctrl K";
  }
</script>

<style is:global>
  .search-heading {
    max-width: 760px;
    padding: 56px 0 28px;
    border-bottom: 1px solid var(--line);
  }

  .search-heading h1 {
    margin-bottom: 12px;
    color: var(--ink);
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .search-library {
    max-width: 760px;
    min-height: 480px;
    padding: 38px 0 20px;
    --pf-text: var(--ink);
    --pf-text-secondary: var(--muted);
    --pf-text-muted: var(--gray-500);
    --pf-background: var(--bg);
    --pf-border: var(--line);
    --pf-border-focus: var(--accent);
    --pf-hover: var(--surface);
    --pf-mark: var(--accent-strong);
    --pf-outline-focus: var(--accent);
    --pf-font: inherit;
    --pf-input-height: 54px;
    --pf-input-font-size: 1.05rem;
    --pf-summary-font-size: 0.84rem;
    --pf-result-title-font-size: 1.25rem;
    --pf-result-excerpt-font-size: 1rem;
    --pf-border-radius: 4px;
    --pf-results-gap: 0;
  }

  .search-field {
    position: relative;
  }

  .search-field pagefind-input {
    display: block;
  }

  .search-shortcut {
    position: absolute;
    top: 50%;
    right: 14px;
    z-index: 2;
    padding: 3px 7px;
    border: 1px solid var(--line);
    border-radius: 3px;
    color: var(--gray-500);
    font-size: 0.72rem;
    line-height: 1.2;
    pointer-events: none;
    transform: translateY(-50%);
  }

  .search-field:has(.pf-input:not(:placeholder-shown)) .search-shortcut {
    display: none;
  }

  pagefind-summary {
    display: block;
    min-height: 34px;
    padding: 14px 0 6px;
    color: var(--muted);
  }

  pagefind-results {
    display: block;
  }

  pagefind-results .pf-results {
    margin: 0;
    padding: 0;
  }

  pagefind-results .philosophia-result {
    padding: 24px 0;
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .philosophia-result__title {
    margin: 0 0 8px;
    color: var(--ink);
    font-size: 1.22rem;
    line-height: 1.3;
  }

  .philosophia-result__title a {
    color: inherit;
    font-weight: 500;
    text-decoration: none;
  }

  .philosophia-result__title a:hover,
  .philosophia-result__title a:focus-visible {
    color: var(--accent);
  }

  .philosophia-result__excerpt {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.68;
  }

  .philosophia-result__excerpt mark {
    background: transparent;
    color: var(--accent-strong);
    font-weight: 500;
  }

  .philosophia-result__sections {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  .philosophia-result__sections a {
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 400;
    text-underline-offset: 3px;
  }

  @media (max-width: 560px) {
    .search-heading {
      padding-top: 34px;
    }

    .search-library {
      padding-top: 28px;
    }

    .search-shortcut {
      display: none;
    }
  }
</style>
