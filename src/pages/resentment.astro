---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const project = await getEntry("projects", "resentment");

if (!project) {
  throw new Error("Missing resentment project entry.");
}

const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <main>
    <header class="page-heading">
      <p class="eyebrow">Projekt</p>
      <h1>{project.data.title}</h1>
      <p class="lead">{project.data.description}</p>
    </header>
    <article class="prose project-body">
      <Content />
    </article>
  </main>
</BaseLayout>

<style>
  .project-body {
    padding-top: 32px;
  }
</style>
