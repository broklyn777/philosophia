---
import BaseLayout from "./BaseLayout.astro";
import ArticleAudioPlayer from "../components/ArticleAudioPlayer.astro";
import SeriesNavigation from "../components/mdx/SeriesNavigation.astro";
import { slugifyTag } from "../lib/content";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  plain?: boolean;
  audioEnabled?: boolean;
  searchable?: boolean;
  seriesNavigation?: {
    indexHref: string;
    indexLabel?: string;
    previousHref?: string;
    previousLabel?: string;
    nextHref?: string;
    nextLabel?: string;
  };
}

const {
  title,
  description,
  date,
  tags,
  plain = false,
  audioEnabled = false,
  searchable = true,
  seriesNavigation,
} = Astro.props;
const formattedDate = new Intl.DateTimeFormat("sv-SE", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(date);
---

<BaseLayout title={title} description={description}>
  <main>
    <article
      class:list={["article-shell", { "article-shell--plain": plain }]}
      data-pagefind-body={searchable || undefined}
    >
      <header
        class:list={["article-header", { "article-header--plain": plain }]}
        data-pagefind-ignore="all"
      >
        {!plain && <p class="eyebrow">Blogg</p>}
        <h1>{title}</h1>
        {!plain && <p class="lead">{description}</p>}
        {
          !plain && (
            <>
              <time datetime={date.toISOString()}>{formattedDate}</time>
              <div class="tags">
                {tags.map((tag) => <a href={`/amnen/${slugifyTag(tag)}/`}>{tag}</a>)}
              </div>
            </>
          )
        }
      </header>
      {audioEnabled && <ArticleAudioPlayer />}
      <div class="prose">
        <slot />
      </div>
      <div data-pagefind-ignore="all">
        {seriesNavigation && <SeriesNavigation {...seriesNavigation} />}
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article-shell {
    padding: 56px 0 20px;
  }

  .article-header {
    max-width: 920px;
    margin-bottom: 34px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
  }

  .article-header--plain {
    max-width: 760px;
    margin-bottom: 18px;
    padding-bottom: 18px;
  }

  time {
    display: block;
    margin-top: 18px;
    font-weight: 700;
  }

  h1 {
    margin-bottom: 16px;
    color: var(--ink);
    font-size: clamp(2.4rem, 6vw, 4.7rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .tags a {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: uppercase;
  }
</style>
