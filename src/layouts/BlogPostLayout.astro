---
import BaseLayout from "./BaseLayout.astro";
import { slugifyTag } from "../lib/content";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("sv-SE", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(date);
---

<BaseLayout title={title} description={description}>
  <main>
    <article class="article-shell">
      <header class="article-header">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <h1>{title}</h1>
        <p>{description}</p>
        <div class="tags">
          {tags.map((tag) => <a href={`/amnen/${slugifyTag(tag)}/`}>{tag}</a>)}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 42px;
    padding: 48px 0 20px;
  }

  .article-header {
    color: var(--muted);
  }

  time {
    display: block;
    margin-bottom: 18px;
    font-weight: 700;
  }

  h1 {
    margin-bottom: 16px;
    color: var(--ink);
    font-size: clamp(2.4rem, 6vw, 4.7rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .article-header p {
    line-height: 1.65;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .tags a {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 840px) {
    .article-shell {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
