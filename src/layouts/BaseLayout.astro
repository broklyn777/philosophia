---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = title === "Philosophia" ? title : `${title} - Philosophia`;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <script is:inline>
      try {
        const storedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = storedTheme ?? (prefersDark ? "dark" : "light");
      } catch {
        document.documentElement.dataset.theme = "light";
      }
    </script>
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
    <script is:inline>
      const themeButton = document.querySelector("[data-theme-toggle]");
      const themeLabel = document.querySelector("[data-theme-label]");

      function updateThemeLabel() {
        const isDark = document.documentElement.dataset.theme === "dark";
        if (themeLabel) themeLabel.textContent = isDark ? "Ljust" : "Mörkt";
        themeButton?.setAttribute("aria-label", isDark ? "Byt till ljust tema" : "Byt till mörkt tema");
      }

      updateThemeLabel();
      themeButton?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch {}
        updateThemeLabel();
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --primary-400: #2dd4bf;
    --primary-500: #14b8a6;
    --primary-600: #0d9488;
    --gray-50: #fafafa;
    --gray-100: #f5f5f5;
    --gray-200: #e5e5e5;
    --gray-300: #d4d4d4;
    --gray-400: #a3a3a3;
    --gray-500: #737373;
    --gray-600: #525252;
    --gray-700: #404040;
    --gray-800: #262626;
    --gray-900: #171717;
    --bg: #ffffff;
    --surface: var(--gray-50);
    --ink: var(--gray-900);
    --muted: var(--gray-700);
    --line: var(--gray-200);
    --accent: var(--primary-500);
    --accent-strong: var(--primary-600);
    --code: #ec4899;
    --max: 1040px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: var(--gray-900);
    --surface: var(--gray-800);
    --ink: var(--gray-100);
    --muted: var(--gray-300);
    --line: var(--gray-700);
    --accent: var(--primary-500);
    --accent-strong: var(--primary-400);
    --code: var(--primary-400);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  main {
    width: min(var(--max), calc(100% - 32px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-heading {
    padding: 56px 0 28px;
    border-bottom: 1px solid var(--line);
  }

  .page-heading h1 {
    margin-bottom: 12px;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .prose {
    max-width: 760px;
    color: var(--muted);
    font-size: 1.18rem;
    line-height: 1.82;
  }

  .prose h2,
  .prose h3 {
    color: var(--ink);
    line-height: 1.18;
  }

  .prose h2 {
    margin-top: 42px;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.02em;
  }

  .prose h3 {
    margin-top: 32px;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
  }

  .prose h4 {
    margin-top: 28px;
    color: var(--ink);
    font-size: 1.18rem;
    line-height: 1.25;
  }

  .prose a {
    color: var(--accent-strong);
    font-weight: 700;
    text-underline-offset: 3px;
  }

  .prose a:hover {
    color: var(--accent);
  }

  .prose .evagrios-index a {
    color: var(--accent);
    font-weight: 500;
    text-decoration-thickness: 1px;
  }

  .prose .evagrios-index a:hover {
    color: var(--accent-strong);
  }

  .prose strong {
    color: var(--gray-600);
  }

  :root[data-theme="dark"] .prose strong {
    color: var(--gray-100);
  }

  .prose code {
    padding: 2px 4px;
    border-radius: 4px;
    background: var(--gray-100);
    color: var(--code);
    font-size: 0.92em;
  }

  :root[data-theme="dark"] .prose code {
    background: var(--gray-800);
  }

  .prose blockquote {
    margin-left: 0;
    padding-left: 18px;
    border-left: 4px solid var(--line);
    color: var(--ink);
    font-weight: 600;
  }

  .prose hr {
    border: 0;
    border-top: 1px solid var(--line);
  }

  .prose li::marker {
    color: var(--gray-500);
    font-weight: 700;
  }

  :root[data-theme="dark"] .prose li::marker {
    color: var(--gray-400);
  }
</style>
