---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ReadingPlayer from "../components/ReadingPlayer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = title === "Philosophia" ? title : `${title} - Philosophia`;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <ClientRouter />
    <slot name="head" />
    <script is:inline>
      try {
        if (!document.documentElement.dataset.theme) {
          const cookieTheme = document.cookie.match(/(?:^|; )theme=(dark|light)/)?.[1];
          const storedTheme = localStorage.getItem("theme") || cookieTheme;
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.dataset.theme = storedTheme ?? (prefersDark ? "dark" : "light");
        }
      } catch {
        if (!document.documentElement.dataset.theme) document.documentElement.dataset.theme = "light";
      }
    </script>
  </head>
  <body>
    <SiteHeader />
    <slot />
    <SiteFooter />
    <ReadingPlayer />
    <script is:inline>
      function updateThemeLabel() {
        const isDark = document.documentElement.dataset.theme === "dark";
        const themeButton = document.querySelector("[data-theme-toggle]");
        const themeLabel = document.querySelector("[data-theme-label]");
        if (themeLabel) themeLabel.textContent = isDark ? "Ljust" : "Mörkt";
        themeButton?.setAttribute("aria-label", isDark ? "Byt till ljust tema" : "Byt till mörkt tema");
      }

      if (!document.documentElement.dataset.themeController) {
        document.documentElement.dataset.themeController = "ready";
        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const themeButton = target.closest("[data-theme-toggle]");
          if (!themeButton) return;

          const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch {}
          document.cookie = `theme=${next}; path=/; max-age=31536000; SameSite=Lax`;
          updateThemeLabel();
        });

        document.addEventListener("astro:before-swap", (event) => {
          const currentTheme = document.documentElement.dataset.theme;
          if (currentTheme && event.newDocument?.documentElement) {
            event.newDocument.documentElement.dataset.theme = currentTheme;
          }
        });
      }

      updateThemeLabel();
      document.addEventListener("astro:after-swap", updateThemeLabel);
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --primary-400: #2dd4bf;
    --primary-500: #14b8a6;
    --primary-600: #0d9488;
    --gray-50: #fafafa;
    --gray-100: #f5f5f5;
    --gray-200: #e5e5e5;
    --gray-300: #d4d4d4;
    --gray-400: #a3a3a3;
    --gray-500: #737373;
    --gray-600: #525252;
    --gray-700: #404040;
    --gray-800: #262626;
    --gray-900: #171717;
    --bg: #ffffff;
    --surface: var(--gray-50);
    --ink: var(--gray-900);
    --muted: var(--gray-700);
    --line: var(--gray-200);
    --accent: var(--primary-500);
    --accent-strong: var(--primary-600);
    --code: #ec4899;
    --max: 1040px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: var(--gray-900);
    --surface: var(--gray-800);
    --ink: var(--gray-100);
    --muted: var(--gray-300);
    --line: var(--gray-700);
    --accent: var(--primary-500);
    --accent-strong: var(--primary-500);
    --code: var(--primary-400);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
  }

  a {
    color: inherit;
  }

  main {
    width: min(var(--max), calc(100% - 32px));
    margin: 0 auto;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-heading {
    padding: 56px 0 28px;
    border-bottom: 1px solid var(--line);
  }

  .page-heading h1 {
    margin-bottom: 12px;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .prose {
    max-width: 760px;
    color: var(--muted);
    font-size: 1.18rem;
    font-weight: 350;
    line-height: 1.82;
  }

  .prose h2,
  .prose h3 {
    color: var(--ink);
    font-weight: 700;
    line-height: 1.18;
  }

  .prose h2 {
    margin-top: 42px;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.02em;
  }

  .prose h3 {
    margin-top: 32px;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
  }

  .prose h4 {
    margin-top: 28px;
    color: var(--ink);
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .prose a {
    color: var(--accent);
    font-weight: 400;
    text-underline-offset: 3px;
  }

  .prose a:hover {
    color: var(--accent);
  }

  .prose .pull-quote {
    margin: 34px 0;
    padding: 20px 0 20px 22px;
    border-left: 3px solid var(--accent);
    color: var(--ink);
  }

  .prose .pull-quote p {
    max-width: 640px;
    margin: 0;
    font-size: clamp(1.35rem, 3vw, 1.8rem);
    font-weight: 650;
    line-height: 1.35;
  }

  .prose .research-overview .research-panel {
    margin: 26px 0;
    padding: 20px 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .prose .research-overview .research-panel p:last-child,
  .prose .research-overview .research-panel ul:last-child {
    margin-bottom: 0;
  }

  .prose .research-overview .research-kicker {
    margin-bottom: 8px;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .prose .evagrios-index a {
    color: var(--accent);
    font-weight: 400;
    text-decoration-thickness: 1px;
  }

  .prose .evagrios-index a:hover {
    color: var(--accent-strong);
  }

  .prose .evagrios-index .section-overview {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin: 22px 0 24px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .prose .evagrios-index .section-overview span {
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
  }

  .prose .evagrios-index .section-overview a {
    font-size: 1.05em;
    text-decoration-thickness: 1px;
  }

  .prose .evagrios-index .section-overview--articles {
    align-items: flex-start;
  }

  .prose .evagrios-index .section-overview--articles > div {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .prose .maximos-index li > span {
    color: var(--muted);
  }

  .prose .maximos-index li small {
    margin-left: 6px;
    color: var(--gray-400);
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .prose .history-index .essay-list {
    display: grid;
    gap: 18px;
    margin: 28px 0 36px;
  }

  .prose .history-index .essay-item {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .prose .history-index .essay-item h4 {
    margin: 0 0 8px;
    color: var(--ink);
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    line-height: 1.15;
  }

  .prose .history-index .essay-kicker {
    margin-bottom: 8px;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .prose .history-index .essay-item span {
    color: var(--ink);
    font-weight: 700;
  }

  .prose .history-index details {
    margin: 16px 0;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .prose .history-index summary {
    color: var(--accent);
    cursor: pointer;
    font-weight: 700;
  }

  .prose .history-index .essay-ending {
    margin-bottom: 0;
    color: var(--ink);
    font-style: italic;
  }

  @media (max-width: 520px) {
    .prose .evagrios-index .section-overview {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
  }

  .prose strong {
    color: var(--gray-600);
  }

  :root[data-theme="dark"] .prose strong {
    color: var(--gray-100);
  }

  .prose code {
    padding: 2px 4px;
    border-radius: 4px;
    background: var(--gray-100);
    color: var(--code);
    font-size: 0.92em;
  }

  :root[data-theme="dark"] .prose code {
    background: var(--gray-800);
  }

  .prose blockquote {
    margin-left: 0;
    padding-left: 18px;
    border-left: 4px solid var(--line);
    color: var(--ink);
    font-weight: 600;
  }

  .prose hr {
    border: 0;
    border-top: 1px solid var(--line);
  }

  .prose li::marker {
    color: var(--gray-500);
    font-weight: 700;
  }

  :root[data-theme="dark"] .prose li::marker {
    color: var(--gray-400);
  }
</style>
